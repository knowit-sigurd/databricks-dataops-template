    {
      "name": "b61ab3c4",
      "displayName": "ops_contract_check_history_v",
      "queryLines": [
        "SELECT table_name, check_name, status, actual_value, expected_value, checked_at\n",
        "FROM dataops_template.prod.ops_contract_check_history_v\n",
        "WHERE checked_at = (SELECT MAX(checked_at) FROM dataops_template.prod.ops_contract_check_history_v)\n"
      ]
    },
    {
      "name": "ba11055f",
      "displayName": "pipeline_checks_all",
      "queryLines": [
        "SELECT pipeline_name, check_name, status, message, checked_at, run_id\n",
        "FROM dataops_template.prod.ops_pipeline_run_history_v\n",
        "WHERE check_type = 'direct'\n",
        "ORDER BY checked_at DESC\n"
      ]
    },
    {
      "name": "reliability_7d",
      "displayName": "7-day reliability",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) FILTER (WHERE overall_status = 'SUCCESS') || ' / ' ||\n",
        "  COUNT(*) || ' runs succeeded' AS reliability\n",
        "FROM dataops_template.prod.ops_run_history_v\n",
        "WHERE started_at >= current_date - INTERVAL 7 DAYS\n"
      ]
    },
    {
      "name": "last_success",
      "displayName": "last successful run",
      "queryLines": [
        "SELECT completed_at AS last_success_at\n",
        "FROM dataops_template.prod.ops_run_history_v\n",
        "WHERE overall_status = 'SUCCESS'\n",
        "ORDER BY completed_at DESC\n",
        "LIMIT 1\n"
      ]
    }
  ],
